<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" styleClass="root" stylesheets="@css/Dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

   <left>
      <VBox prefHeight="844.0" prefWidth="201.0" spacing="5" styleClass="sidebar">
         <padding>
            <Insets bottom="20" left="10" right="10" top="20" />
         </padding>
         
         <VBox spacing="5" styleClass="brand-section">
            <VBox.margin>
               <Insets bottom="20" left="10" />
            </VBox.margin>
            <Label styleClass="brand-title" text="Metramoelyatama" textFill="#5f5157" />
            <Label styleClass="brand-subtitle" text="EDITORIAL TRANQUILITY" />
         </VBox>
         
         <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="menu-scroll" VBox.vgrow="ALWAYS">
            <VBox fx:id="menuContainer" spacing="5">
           
               <Button fx:id="menuHome" prefHeight="42.0" prefWidth="245.0" styleClass="menu-item, active" text="Home" textFill="#5f5157">
                  <graphic>
                     <FontIcon iconColor="#473a40" iconLiteral="fas-home" iconSize="20" />
                  </graphic>
               </Button>
            
               <VBox spacing="2">
                  <Button fx:id="menuMaster" onAction="#toggleMaster" prefHeight="42.0" prefWidth="246.0" styleClass="menu-item" text="Master" textFill="#5f5157">
                     <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                           <FontIcon iconColor="#473a40" iconLiteral="fas-database" iconSize="20" />
                           <Region HBox.hgrow="ALWAYS" />
                           <FontIcon fx:id="iconMaster" iconColor="#473a40" iconLiteral="fas-chevron-down" iconSize="14" />
                        </HBox>
                     </graphic>
                  </Button>
                  
                  <VBox fx:id="submenuMaster" managed="false" spacing="2" visible="false">
                     <padding>
                        <Insets left="20" />
                     </padding>
                     
                     <Button fx:id="menuClients" styleClass="submenu-item" text="Client">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-building" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuKaryawan" styleClass="submenu-item" text="Karyawan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-user-tie" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuSupplier" styleClass="submenu-item" text="Supplier">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-truck" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuLayanan" styleClass="submenu-item" text="Jenis Layanan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-clipboard-list" iconSize="16" />
                        </graphic>
                     </Button>
                  </VBox>
               </VBox>
            
               <VBox spacing="2">
                  <Button fx:id="menuTransaksi" onAction="#toggleTransaksi" prefHeight="42.0" prefWidth="243.0" styleClass="menu-item" text="Transaksi" textFill="#5f5157">
                     <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                           <FontIcon iconColor="#473a40" iconLiteral="fas-file-invoice" iconSize="20" />
                           <Region HBox.hgrow="ALWAYS" />
                           <FontIcon fx:id="iconTransaksi" iconColor="#473a40" iconLiteral="fas-chevron-down" iconSize="14" />
                        </HBox>
                     </graphic>
                  </Button>
                  
                  <VBox fx:id="submenuTransaksi" managed="false" spacing="2" visible="false">
                     <padding>
                        <Insets left="20" />
                     </padding>
                     
                     <Button fx:id="menuOrder" styleClass="submenu-item" text="Orders">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-shopping-cart" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuPengerjaan" styleClass="submenu-item" text="Pengerjaan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-tasks" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuInvoice" styleClass="submenu-item" text="Invoice">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-file-invoice-dollar" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuPembelian" styleClass="submenu-item" text="Pembelian">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-cart-plus" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuPenjualan" styleClass="submenu-item" text="Penjualan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-money-bill-wave" iconSize="16" />
                        </graphic>
                     </Button>
                  </VBox>
               </VBox>
            
               <VBox spacing="2">
                  <Button fx:id="menuInventory" onAction="#toggleInventory" prefHeight="42.0" prefWidth="244.0" styleClass="menu-item" text="Inventory" textFill="#5f5157">
                     <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                           <FontIcon iconColor="#473a40" iconLiteral="fas-archive" iconSize="20" />
                           <Region HBox.hgrow="ALWAYS" />
                           <FontIcon fx:id="iconInventory" iconColor="#473a40" iconLiteral="fas-chevron-down" iconSize="14" />
                        </HBox>
                     </graphic>
                  </Button>
                  
                  <VBox fx:id="submenuInventory" managed="false" spacing="2" visible="false">
                     <padding>
                        <Insets left="20" />
                     </padding>
                     
                     <Button fx:id="menuBarang" styleClass="submenu-item" text="Barang">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-box" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuStokBarang" styleClass="submenu-item" text="Stok Barang">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-boxes" iconSize="16" />
                        </graphic>
                     </Button>
                  </VBox>
               </VBox>
            
               <VBox spacing="2">
                  <Button fx:id="menuLaporan" onAction="#toggleLaporan" prefHeight="42.0" prefWidth="239.0" styleClass="menu-item" text="Laporan" textFill="#5f5157">
                     <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                           <FontIcon iconColor="#473a40" iconLiteral="fas-chart-bar" iconSize="20" />
                           <Region HBox.hgrow="ALWAYS" />
                           <FontIcon fx:id="iconLaporan" iconColor="#473a40" iconLiteral="fas-chevron-down" iconSize="14" />
                        </HBox>
                     </graphic>
                  </Button>
                  
                  <VBox fx:id="submenuLaporan" managed="false" spacing="2" visible="false">
                     <padding>
                        <Insets left="20" />
                     </padding>
                     
                     <Button fx:id="menuLaporanOrder" styleClass="submenu-item" text="Laporan Order">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-file-alt" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuLaporanPengerjaan" styleClass="submenu-item" text="Laporan Pengerjaan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-clipboard-check" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuLaporanInvoice" styleClass="submenu-item" text="Laporan Invoice">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-receipt" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuLaporanPembelian" styleClass="submenu-item" text="Laporan Pembelian">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-shopping-bag" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuLaporanPenjualan" styleClass="submenu-item" text="Laporan Penjualan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-cash-register" iconSize="16" />
                        </graphic>
                     </Button>
                     
                     <Button fx:id="menuLaporanKeuntungan" styleClass="submenu-item" text="Laporan Keuntungan">
                        <graphic>
                           <FontIcon iconColor="#73726c" iconLiteral="fas-chart-line" iconSize="16" />
                        </graphic>
                     </Button>
                  </VBox>
               </VBox>
            
            </VBox>
         </ScrollPane>
         
         <Region VBox.vgrow="ALWAYS" />
         
         <Button fx:id="btnLogout" onAction="#handleLogout" prefHeight="40.0" prefWidth="248.0" styleClass="btn-logout" text="🚪  Logout" textFill="#ae1515">
            <VBox.margin>
               <Insets top="20" />
            </VBox.margin>
            <graphic>
               <FontIcon iconColor="#473a40" iconLiteral="fas-sign-out-alt" iconSize="20" />
            </graphic>
         </Button>
      </VBox>
   </left>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="150.0" spacing="15.0" styleClass="top-bar" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="20" right="20" />
         </padding>
         <VBox alignment="CENTER_RIGHT" layoutX="1012.0" layoutY="10.0" prefHeight="55.0" prefWidth="200.0" spacing="2">
            <children>
               <Label fx:id="lblPageTitle" prefHeight="29.0" prefWidth="217.0" styleClass="user-title" text="Home Dashboard" textFill="#5f5157" />
            </children>
         </VBox>
         <Region prefHeight="55.0" prefWidth="76.0" />
         <Region layoutX="30.0" layoutY="10.0" prefHeight="55.0" prefWidth="930.0" />
         
          <VBox alignment="CENTER" prefHeight="59.0" prefWidth="77.0" spacing="2">
            <Label fx:id="lblUserRole" styleClass="user-role" text="Administrator" />
            <Label fx:id="lblUserName" styleClass="user-name" text="Santoso" />
         </VBox>
      </HBox>
   </top>
   
   <center>
    <StackPane fx:id="mainForm" BorderPane.alignment="CENTER" />
   </center>

</BorderPane>
